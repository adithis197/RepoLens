{
  "manifest_version": 3,
  "name": "RepoLens",
  "version": "0.1.0",
  "description": "Generate traceable architecture diagrams for GitHub repos",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["https://github.com/*", "http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["src/content.js"]
    }
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  }
}